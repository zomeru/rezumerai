# OCI Object Storage Backend for Terraform State
# 
# Use this if you want to store Terraform state in OCI Object Storage instead of locally.
# This is useful for team collaboration or if you want remote state storage.
#
# For single-user setups, the default local backend is simpler and recommended.
#
# To use this backend:
#
# 1. Create the bucket first:
#    oci os bucket create \
#      --compartment-id <compartment-ocid> \
#      --name rezumerai-terraform-state
#
# 2. Get your namespace:
#    oci os ns get
#
# 3. Copy this file to backend.tf (replacing the local backend in main.tf):
#    cp backend-oci.tf.example backend.tf
#
# 4. Update the namespace below
#
# 5. Initialize with migration:
#    terraform init -migrate-state
#
# Note: The OCI backend requires the oci Terraform provider >= 5.0.0

terraform {
  backend "oci" {
    bucket    = "rezumerai-terraform-state"
    namespace = "your-namespace-here"  # Replace with your OCI namespace
    object    = "prod/terraform.tfstate"
    region    = "us-ashburn-1"
    
    # These can also be set via environment variables:
    # export TF_BACKEND_OCI_TENANCY_OCID="ocid1.tenancy.oc1.."
    # export TF_BACKEND_OCI_USER_OCID="ocid1.user.oc1.."
    # export TF_BACKEND_OCI_FINGERPRINT="xx:xx:xx:..."
    # export TF_BACKEND_OCI_PRIVATE_KEY_PATH="~/.oci/oci_api_key.pem"
  }
}
