    "@tiptap/extension-text-style": "3.20.4",
    "@tiptap/extension-underline": "3.20.4",
    "@tiptap/pm": "3.20.4",
    "@tiptap/react": "3.20.4",
    "@tiptap/starter-kit": "3.20.5",
    "ai": "^6.0.116",
    "better-auth": "^1.5.5",
    "botid": "^1.5.11",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
