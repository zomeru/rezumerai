    "pg-boss": "^12.14.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
