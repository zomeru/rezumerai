{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "bun scripts/download-pdf-worker.ts",
    "prebuild": "bun scripts/download-pdf-worker.ts",
    "dev": "bun run with-env next dev",
    "build": "bun run with-env next build",
    "start": "bun run prepare:standalone && bun run with-env node .next/standalone/apps/web/server.js",
    "prepare:standalone": "bun scripts/prepare-standalone-assets.ts",
    "assistant:reindex-memory": "bun run with-env bun ./scripts/reindex-assistant-memory.ts",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "analyze": "ANALYZE=true bun run build --webpack",
    "check": "biome check --write .",
    "clean": "rimraf .next node_modules .turbo coverage tsconfig.tsbuildinfo",
    "with-env": "dotenv -e ../../.env.local --"
  },
