{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "bun scripts/download-pdf-worker.ts",
    "prebuild": "bun scripts/download-pdf-worker.ts",
    "dev": "bun run with-env next dev",
    "build": "bun run with-env next build",
    "start": "bun run prepare:standalone && bun run with-env bun .next/standalone/apps/web/server.js",
    "prepare:standalone": "bun scripts/prepare-standalone-assets.ts",
    "worker": "bun run with-env bun src/worker.ts",
    "worker:all": "bun run with-env bun src/worker.ts --jobs=generate-embeddings,reindex-conversation,record-analytics,record-audit-log,error-log-retention-cleanup",
    "worker:embeddings": "bun run with-env bun src/worker.ts --jobs=generate-embeddings,reindex-conversation",
    "worker:observability": "bun run with-env bun src/worker.ts --jobs=record-analytics,record-audit-log",
    "assistant:reindex-memory": "bun run with-env node ./scripts/reindex-assistant-memory.ts",
    "benchmark:report": "bun run with-env bun ./scripts/benchmark-report.ts",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "analyze": "ANALYZE=true bun run build --webpack",
    "check": "biome check --write .",
    "clean": "rimraf .next node_modules .turbo coverage tsconfig.tsbuildinfo",
    "with-env": "dotenv -e ../../.env.local --"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@better-auth/prisma-adapter": "^1.5.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "@langchain/textsplitters": "^1.0.1",
    "@node-rs/argon2": "^2.0.2",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@react-pdf/renderer": "^4.3.2",
    "@rezumerai/database": "workspace:*",
    "@rezumerai/types": "workspace:*",
    "@rezumerai/ui": "workspace:*",
    "@rezumerai/utils": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
