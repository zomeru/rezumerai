# Rezumerai environment template
# Copy this file to the environment-specific variant you need and replace placeholder values.

# Database
# DATABASE_URL is used by the Prisma client at runtime.
# DIRECT_URL is used by Prisma CLI operations such as migrate and generate.
DATABASE_URL="postgresql://your_username:your_secure_password@localhost:5432/db_name"
DIRECT_URL="postgresql://your_username:your_secure_password@localhost:5432/db_name"

# Scheduling and background jobs
CRON_SECRET="your_cron_secret_here"

# Public app URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Optional. Only set this if you expose a separate public API origin.
# NEXT_PUBLIC_API_URL="http://localhost:8080"

# Authentication
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your_better_auth_secret_here"
BETTER_AUTH_GITHUB_CLIENT_ID="your_github_client_id_here"
BETTER_AUTH_GITHUB_CLIENT_SECRET="your_github_client_secret_here"
# Optional Google OAuth configuration
BETTER_AUTH_GOOGLE_CLIENT_ID="your_google_client_id_here"
BETTER_AUTH_GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# AI
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Local seeding
# Optional. Used by packages/database/scripts/seed.ts during local development.
DB_SEED_USER_EMAIL="your_seed_user_email_here"
