{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_SITE_URL",
        "BETTER_AUTH_GOOGLE_CLIENT_ID",
        "BETTER_AUTH_GOOGLE_CLIENT_SECRET",
        "BETTER_AUTH_GITHUB_CLIENT_ID",
        "BETTER_AUTH_GITHUB_CLIENT_SECRET",
        "CRON_SECRET",
        "REDIS_URL",
        "OPENROUTER_API_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env.local", ".env"]
    },
    "start": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "check": {},
    "check:types": {
      "dependsOn": ["^check:types"]
    },
    "test": {
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_SITE_URL",
        "BETTER_AUTH_GOOGLE_CLIENT_ID",
        "BETTER_AUTH_GOOGLE_CLIENT_SECRET",
        "BETTER_AUTH_GITHUB_CLIENT_ID",
        "BETTER_AUTH_GITHUB_CLIENT_SECRET",
        "CRON_SECRET",
        "REDIS_URL",
        "OPENROUTER_API_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env.local", ".env"]
    },
    "clean": {
      "cache": false
    }
  }
}
