{
  "name": "@rezumerai/utils",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./date": "./dist/date.mjs",
    "./react": "./dist/react.mjs",
    "./schema-validation": "./dist/schema-validation.mjs",
    "./string": "./dist/string.mjs",
    "./styles": "./dist/styles.mjs",
    "./uuid": "./dist/uuid.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "biome check --write .",
    "clean": "rimraf node_modules .turbo dist coverage tsconfig.tsbuildinfo tsdown.config.bundled*"
  },
  "dependencies": {
    "@rezumerai/types": "workspace:*",
    "@types/react": "^19.2.14",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@rezumerai/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2"
  }
}
