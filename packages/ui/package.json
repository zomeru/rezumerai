{
  "name": "@rezumerai/ui",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist/**",
    "src/**",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "global.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components.d.mts",
      "import": "./dist/components.mjs"
    },
    "./globals.css": "./global.css",
    "./postcss.config": "./postcss.config.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "generate:component": "turbo gen react-component",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "biome check --write .",
    "clean": "rimraf node_modules .turbo dist coverage tsconfig.tsbuildinfo tsdown.config.bundled*"
  },
  "dependencies": {
    "@rezumerai/types": "workspace:*",
    "@rezumerai/utils": "workspace:*",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@rezumerai/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3"
  }
}
