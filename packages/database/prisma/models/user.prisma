model User {
  id                              String                             @id
  name                            String
  email                           String                             @unique
  emailVerified                   Boolean
  image                           String?
  createdAt                       DateTime
  updatedAt                       DateTime
  role                            UserRole                           @default(USER)
  selectedAiModel                 String                             @default("openrouter/free") @map("selected_ai_model")
  lastPasswordChangeAt            DateTime?
  banned                          Boolean                            @default(false)
  banReason                       String?
  banExpires                      DateTime?
  isAnonymous                     Boolean                            @default(false)
  accounts                        Account[]
  assistantConversations          AiAssistantConversation[]
  assistantConversationEmbeddings AiAssistantConversationEmbedding[]
  aiTextOptimizerCredits          AiTextOptimizerCredits?
  analyticsEvents                 AnalyticsEvent[]                   @relation("AnalyticsEventUser")
  auditLogs                       AuditLog[]                         @relation("AuditLogActor")
  readErrorLogs                   ErrorLog[]                         @relation("ErrorLogReadByUser")
  errorLogs                       ErrorLog[]                         @relation("ErrorLogUser")
  resumes                         Resume[]
  sessions                        Session[]

  @@index([role, createdAt])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String    @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

enum UserRole {
  ADMIN
  USER

  @@map("user_role")
}
