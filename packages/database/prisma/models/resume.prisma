model Resume {
  id                  String               @id @default(cuid())
  userId              String
  title               String               @default("")
  public              Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  professionalSummary String               @default("")
  template            TemplateType         @default(classic)
  accentColor         String               @default("#000000")
  fontSize            FontSizePreset       @default(medium)
  customFontSize      Float                @default(1)
  skills              String[]             @default([])
  education           Education[]
  experience          Experience[]
  personalInfo        PersonalInformation?
  project             Project[]
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([public])
  @@map("resume")
}

model PersonalInformation {
  id         String @id @default(cuid())
  resumeId   String @unique
  fullName   String @default("")
  email      String @default("")
  phone      String @default("")
  location   String @default("")
  linkedin   String @default("")
  website    String @default("")
  profession String @default("")
  image      String @default("")
  resume     Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("personal_information")
}

model Experience {
  id          String    @id @default(cuid())
  resumeId    String
  company     String    @default("")
  position    String    @default("")
  description String    @default("")
  isCurrent   Boolean   @default(false)
  startDate   DateTime
  endDate     DateTime?
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("experience")
}

model Education {
  id                  String    @id @default(cuid())
  resumeId            String
  institution         String    @default("")
  degree              String    @default("")
  field               String    @default("")
  gpa                 String    @default("")
  graduationDate      DateTime?
  schoolYearStartDate DateTime
  isCurrent           Boolean   @default(false)
  resume              Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("education")
}

model Project {
  id          String @id @default(cuid())
  resumeId    String
  name        String @default("")
  type        String @default("")
  description String @default("")
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("projects")
}

enum TemplateType {
  classic
  modern
  minimal
  minimal_image

  @@map("template_type")
}

enum FontSizePreset {
  small
  medium
  large
  custom

  @@map("font_size_preset")
}
