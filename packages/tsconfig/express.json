{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ExpressJS Server",
  "extends": "./base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "ESNext",
    "paths": {
      "@/*": [".src/*"],
      "@rezumerai/types": ["../types/src"],
      "@rezumerai/types/*": ["../types/src/*"],
      "@rezumerai/utils": ["../utils/src"],
      "@rezumerai/utils/*": ["../utils/src/*"]
    },
    "baseUrl": "./src"
  }
}
