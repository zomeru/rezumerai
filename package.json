{
  "name": "rezumerai",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@happy-dom/global-registrator": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "16.3.3",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.15",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{js,jsx,ts,tsx}": [
      "biome check --write --staged"
    ],
    "*.{json,md,yaml,yml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "body-parser": "^2.2.1",
    "hono": "^4.12.5",
    "valibot": "^1.2.0",
    "lodash": "4.17.23"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "predev": "turbo run build --filter=@rezumerai/database",
    "build": "turbo build",
    "build:production": "NODE_ENV=production turbo build",
    "build:packages": "turbo build --filter=./packages/*",
    "dev": "turbo dev",
    "start": "turbo start",
    "check": "bun run update:biome-configs && turbo check",
    "biome": "bun run update:biome-configs && biome check --write  .",
    "update:biome-configs": "bun scripts/update-biome-config-version.ts",
    "check:types": "turbo check:types",
    "code:check": "bun run check && bun run check:types",
    "code:verify": "bun run code:check && bun run test && bun run build",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "changeset": "changeset",
    "publish:packages": "changeset publish",
    "version:packages": "turbo build && changeset version",
    "db:generate": "cd packages/database && bun run db:generate",
    "db:push": "cd packages/database && bun run db:push",
    "db:migrate": "cd packages/database && bun run db:migrate",
    "db:migrate:dev": "cd packages/database && bun run db:migrate:dev",
    "db:migrate:status": "cd packages/database && bun run db:migrate:status",
    "db:seed": "cd packages/database && bun run db:seed",
    "db:seed:ai": "cd packages/database && bun run db:seed:ai",
    "assistant:reindex-memory": "cd apps/web && bun run assistant:reindex-memory",
    "db:pull": "cd packages/database && bun run db:pull",
    "db:psql": "cd packages/database && bun run db:psql",
    "db:inspect-vectors": "cd packages/database && bun run db:inspect-vectors",
    "db:setup": "cd packages/database && bun run db:push && bun run db:generate",
    "db:studio": "cd packages/database && bun run db:studio",
    "db:reset": "cd packages/database && bun run with-env prisma migrate reset --force",
    "docker:build": "./scripts/docker-compose-build.sh",
    "docker:build:standalone": "./scripts/docker-build.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "start:redis": "docker compose up -d redis",
    "install:modules": "bun install && turbo run build --filter=./packages/*",
    "update:modules": "bun update --latest && bun update --latest --interactive --recursive",
    "clean": "turbo clean && rimraf node_modules .turbo tsconfig.tsbuildinfo .playwright-mcp coverage",
    "clean:install": "turbo clean && rimraf node_modules .turbo && bun install && turbo run build --filter=./packages/*",
    "outdated": "bun outdated",
    "security:audit": "bun audit --production",
    "security:check": "bunx audit-ci --config .audit-ci.json",
    "prepare": "husky"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@swc/core",
    "esbuild",
    "prisma",
    "sharp"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
