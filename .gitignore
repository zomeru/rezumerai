####################################
# Dependencies
####################################
**/node_modules/
.pnp
.pnp.js

####################################
# Build outputs
####################################
.next/
out/
build/
dist/
coverage/
.turbo/
.vercel/

####################################
# Environment files
####################################
.env
.env.*
!.env.example

####################################
# Logs
####################################
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

####################################
# Lockfiles (Bun-only repo)
####################################
package-lock.json
yarn.lock
pnpm-lock.yaml

####################################
# Bun
####################################
.bun/

####################################
# OS / Editor junk
####################################
.DS_Store
Thumbs.db
*.pem

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

####################################
# TypeScript / JS build artifacts
####################################
*.tsbuildinfo
next-env.d.ts

# Compiled JS accidentally emitted into src
**/src/**/*.js
**/src/**/*.jsx
**/src/**/*.d.ts.map

# Allow config files
!**/*.config.js
!**/*.config.mjs
!**/*.config.ts

####################################
# Testing (Playwright, Vitest, etc.)
####################################
/test-results/
/playwright-report/
/playwright/.cache/

####################################
# Tooling / AI / MCP
####################################
.serena
.playwright-mcp
.agent-files/feature-requests
.claude/worktrees
.claude/settings.local.json
docs

####################################
# App / Package generated output
####################################
apps/web/public/pdf-worker
apps/api/server
packages/database/generated
.worktrees/
